<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <base-config>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">c.lencr.org</domain> <!-- Allow CRL download for Let's Encrypt CAs -->
    </domain-config>
</network-security-config>